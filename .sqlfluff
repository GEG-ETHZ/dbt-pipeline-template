[sqlfluff]
dialect = bigquery
templater = dbt
runaway_limit = 10
max_line_length = 80
indent_unit = space
exclude_rules = L034, L031, LT01

[sqlfluff:indentation]
tab_space_size = 4

[sqlfluff:layout:type:comma]
spacing_before = 0
spacing_after = 1
line_position = trailing

[sqlfluff:templater:dbt]
project_dir = .
profile = dbt-pipeline-template
target = dev
